(*
 * Hand-written EXPRESS schema fragment for kSTEP smoke-test purposes only.
 * Structurally inspired by the entity names found in ISO 10303-41 / AP242 MIM,
 * but this is an original, minimal subset written for kSTEP — not a copy of
 * any licensed AP242/AP242 EXPRESS schema source.
 *)

SCHEMA ap242_subset;

ENTITY person_and_organization;
  the_person       : STRING;
  the_organization : STRING;
WHERE
  wr1: NOT ((SELF.the_person = '') AND (SELF.the_organization = ''));
END_ENTITY;

ENTITY approval;
  status         : STRING;
  level          : INTEGER;
  authorized_by  : person_and_organization;
WHERE
  wr1: SELF.level >= 0;
END_ENTITY;

ENTITY product;
  id          : STRING;
  name        : STRING;
  description : STRING;
WHERE
  wr1: SELF.id <> '';
END_ENTITY;

ENTITY product_definition_formation;
  id             : STRING;
  description    : STRING;
  of_product     : product;
END_ENTITY;

ENTITY product_definition;
  id          : STRING;
  description : STRING;
  formation   : product_definition_formation;
WHERE
  wr1: SELF.id <> '';
END_ENTITY;

ENTITY next_assembly_usage_occurrence;
  id                           : STRING;
  name                         : STRING;
  relating_product_definition  : product_definition;
  related_product_definition   : product_definition;
  reference_designator         : STRING;
WHERE
  wr1: (SELF.id <> '') AND (SELF.reference_designator <> '');
END_ENTITY;

END_SCHEMA;
