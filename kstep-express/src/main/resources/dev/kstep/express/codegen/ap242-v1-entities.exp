(*
  Real AP242 V1-entity extraction.

  The six entities below (product, product_definition,
  product_definition_formation, next_assembly_usage_occurrence, approval,
  person_and_organization) are copied verbatim from the official
  ap242ed2_dis2_mim_lf_v1.101.exp (ISO TS 10303-442 AP242 "managed model
  based 3d engineering", EXPRESS MIM Long Form, v1.101, 2019) — see /NOTICE
  for full provenance and licensing rationale. The complete, unmodified
  2,122-entity schema (49,942 lines) is not vendored in this repository,
  only this excerpt.

  Also copied verbatim: the three TYPE declarations (identifier, label,
  text) and ten ENTITYs (product_context, product_definition_context,
  approval_status, person, organization, application_context_element,
  application_context, product_definition_relationship,
  product_definition_usage, assembly_component_usage) the six entities'
  attribute types reference, directly or (for the last three, and for
  application_context_element) via SUBTYPE OF. In the official schema (a
  single SCHEMA block with no USE/REFERENCE FROM) every name resolves
  within it; this extraction preserves that property standalone by
  including exactly the supporting declarations needed for
  dev.kstep.express.semantic.ExpressSemanticModelBuilder's named-type
  symbol resolution, and dev.kstep.express.semantic.InheritanceResolver's
  SUBTYPE OF attribute flattening, to succeed.

  ADAPTED, not verbatim (two spots, both deliberate truncations of the
  real schema text — see kSTEP's M2 SUBTYPE-OF-codegen wave plan for the
  stop-and-flag rationale):

  - product_definition_relationship.relating_product_definition and
    .related_product_definition are typed `product_definition` here.
    The real schema types them `product_definition_or_reference`, a
    SELECT type (introduced in the move from AP203/214 to AP242) that
    is not itself vendored — resolving a SELECT type has no Kotlin
    mapping in dev.kstep.express.codegen.TypeMapping (V1 scope, see
    README), and vendoring the SELECT plus its full list of selectable
    entity types would balloon this excerpt well past the "minimal,
    gap-driven" precedent NOTICE documents. `product_definition` is the
    common/expected case for AP242's own product-structure entities, so
    this narrows the SELECT to its most useful member rather than
    resolving it in full.
  - assembly_component_usage's real SUPERTYPE OF lists further sibling
    entities (multi_level_reference_designator,
    promissory_usage_occurrence, specified_higher_usage_occurrence,
    quantified_assembly_component_usage) that are not vendored here;
    product_definition_usage's real SUPERTYPE OF likewise lists
    make_from_usage_option; application_context_element's real
    SUPERTYPE OF likewise lists product_concept_context. All three
    SUPERTYPE OF clauses are kept verbatim in full below (the
    `supertypeConstraintRawText` capture never resolves these names
    against the symbol table — same pre-existing treatment as
    product_definition's own SUPERTYPE OF ONEOF list a few lines down,
    which already names types this excerpt never vendored either), so
    this is not actually a truncation of parseable structure, only of
    which of the *named* ONEOF branches happen to have their own
    ENTITY declaration in this file.

  Three of the ten supporting entities (product_definition_relationship,
  product_definition_usage, assembly_component_usage) exist ONLY to make
  next_assembly_usage_occurrence's SUBTYPE OF chain resolve and flatten;
  dev.kstep.express.codegen.Ap242V1CodeGen deliberately does not emit
  Kotlin classes for them (nothing in the six target entities'
  generated Kotlin references them as an attribute type) — see that
  file's SUPPORT_ENTITY_NAMES comment.

  This file is used by the generateExpressKotlin Gradle task (see
  kstep-express/build.gradle.kts) and by kstep-tests'
  Ap242V1CodeGenTest/ExpressCodeGenTest, which regenerate/verify the six V1
  entities against this real-schema ground truth (M1 Welle 4; SUBTYPE OF
  attribute flattening added in the M2 SUBTYPE-OF-codegen wave).
*)

SCHEMA ap242_v1_entities;

TYPE identifier = STRING;
END_TYPE;

TYPE label = STRING;
END_TYPE;

TYPE text = STRING;
END_TYPE;

ENTITY application_context;
  application : label;
DERIVE
  description : text       := get_description_value(SELF);
  id          : identifier := get_id_value(SELF);
INVERSE
  context_elements : SET [1:?] OF application_context_element FOR frame_of_reference;
WHERE
  WR1: SIZEOF(USEDIN(SELF, 'AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DESCRIPTION_ATTRIBUTE.DESCRIBED_ITEM')) <=
       1;
  WR2: SIZEOF(USEDIN(SELF, 'AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.ID_ATTRIBUTE.IDENTIFIED_ITEM')) <= 1;
END_ENTITY;

ENTITY application_context_element
  SUPERTYPE OF (ONEOF(product_concept_context, product_context, product_definition_context));
  name               : label;
  frame_of_reference : application_context;
END_ENTITY;

ENTITY product_context
  SUBTYPE OF (application_context_element);
  discipline_type : label;
END_ENTITY;

ENTITY product_definition_context
  SUBTYPE OF (application_context_element);
  life_cycle_stage : label;
END_ENTITY;

ENTITY approval_status;
  name : label;
END_ENTITY;

ENTITY person;
  id            : identifier;
  last_name     : OPTIONAL label;
  first_name    : OPTIONAL label;
  middle_names  : OPTIONAL LIST [1 : ?] OF label;
  prefix_titles : OPTIONAL LIST [1 : ?] OF label;
  suffix_titles : OPTIONAL LIST [1 : ?] OF label;
WHERE
  WR1: EXISTS(last_name) OR EXISTS(first_name);
END_ENTITY;

ENTITY organization;
  id          : OPTIONAL identifier;
  name        : label;
  description : OPTIONAL text;
END_ENTITY;

ENTITY product;
  id                 : identifier;
  name               : label;
  description        : OPTIONAL text;
  frame_of_reference : SET [1 : ?] OF product_context;
END_ENTITY;

ENTITY product_definition
  SUPERTYPE OF (ONEOF(composite_assembly_sequence_definition, laminate_table, ply_laminate_sequence_definition));
  id                 : identifier;
  description        : OPTIONAL text;
  formation          : product_definition_formation;
  frame_of_reference : product_definition_context;
DERIVE
  name : label := get_name_value(SELF);
WHERE
  WR1: SIZEOF(USEDIN(SELF, 'AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.NAME_ATTRIBUTE.NAMED_ITEM')) <= 1;
END_ENTITY;

ENTITY product_definition_formation;
  id          : identifier;
  description : OPTIONAL text;
  of_product  : product;
UNIQUE
  UR1: id, of_product;
END_ENTITY;

-- ADAPTED, not verbatim: relating_product_definition/related_product_definition are typed
-- `product_definition` here, not the real schema's `product_definition_or_reference` SELECT
-- type -- see this file's header comment for the full rationale.
ENTITY product_definition_relationship;
  id                          : identifier;
  name                        : label;
  description                 : OPTIONAL text;
  relating_product_definition : product_definition;
  related_product_definition  : product_definition;
END_ENTITY;

ENTITY product_definition_usage
  SUPERTYPE OF (ONEOF(make_from_usage_option, assembly_component_usage))
  SUBTYPE OF (product_definition_relationship);
UNIQUE
  UR1: SELF\product_definition_relationship.id, SELF\product_definition_relationship.relating_product_definition,
       SELF\product_definition_relationship.related_product_definition;
WHERE
  WR1: acyclic_product_definition_relationship(SELF, [SELF\product_definition_relationship.related_product_definition],
                                               'AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.PRODUCT_DEFINITION_USAGE');
END_ENTITY;

ENTITY assembly_component_usage
  SUPERTYPE OF (quantified_assembly_component_usage ANDOR
                ONEOF(multi_level_reference_designator, next_assembly_usage_occurrence, promissory_usage_occurrence,
                      specified_higher_usage_occurrence))
  SUBTYPE OF (product_definition_usage);
  reference_designator : OPTIONAL identifier;
END_ENTITY;

ENTITY next_assembly_usage_occurrence
  SUBTYPE OF (assembly_component_usage);
DERIVE
  product_definition_occurrence_id : identifier := SELF\product_definition_relationship.related_product_definition\product_definition_occurrence.id;
UNIQUE
  UR1: SELF\assembly_component_usage.reference_designator,
       SELF\product_definition_relationship.relating_product_definition;
  UR2: product_definition_occurrence_id, SELF\product_definition_relationship.relating_product_definition;
END_ENTITY;

ENTITY approval;
  status : approval_status;
  level  : label;
END_ENTITY;

ENTITY person_and_organization;
  the_person       : person;
  the_organization : organization;
DERIVE
  name        : label := get_name_value(SELF);
  description : text  := get_description_value(SELF);
WHERE
  WR1: SIZEOF(USEDIN(SELF, 'AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.NAME_ATTRIBUTE.NAMED_ITEM')) <= 1;
  WR2: SIZEOF(USEDIN(SELF, 'AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF.DESCRIPTION_ATTRIBUTE.DESCRIBED_ITEM')) <=
       1;
END_ENTITY;

END_SCHEMA;
